# Public (safe for the browser — never put secrets here)
# Must be the API gateway URL, e.g. https://<project-ref>.supabase.co or http://127.0.0.1:54321
# Do NOT use a supabase.com/dashboard URL.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# Dashboard label: "anon" / "publishable" key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Server-only (never expose via NEXT_PUBLIC_*)
# Dashboard label: "service_role" / "secret" key — optional unless privileged client is used
SUPABASE_SECRET_KEY=your-secret-key

# Application
APP_URL=http://localhost:3000
APP_ENV=development

# Registration: bootstrap_only | invite_only | open
# open is rejected when APP_ENV=production
REGISTRATION_MODE=bootstrap_only
# Required when REGISTRATION_MODE=bootstrap_only (normalized to lowercase)
BOOTSTRAP_EMAIL=you@example.com

# Invitation link lifetime in hours (default 168 = 7 days)
INVITATION_TTL_HOURS=168

DEFAULT_TIMEZONE=America/Chicago
DEFAULT_CURRENCY=USD
