# Public (safe for the browser — never put secrets here)
# Must be the API gateway URL, e.g. https://<project-ref>.supabase.co or http://127.0.0.1:54321
# Do NOT use a supabase.com/dashboard URL.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# Dashboard label: "anon" / "publishable" key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Web Push (public half of the VAPID key pair — safe for the browser)
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Server-only (never expose via NEXT_PUBLIC_*)
# Dashboard label: "service_role" / "secret" key — optional unless privileged client is used
SUPABASE_SECRET_KEY=your-secret-key

# Web Push private key + subject (mailto: or https URL). Required to send push.
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@example.com

# Internal worker secrets (Authorization: Bearer …) — each family is distinct
# Used by cron → matching /api/internal/* endpoints. Never put these in client bundles.
NOTIFICATION_WORKER_SECRET=
DOCUMENT_JOB_WORKER_SECRET=
EXPORT_WORKER_SECRET=
# Reserved for Completion-D offline sync worker
SYNC_WORKER_SECRET=

# Receipt OCR
# RECEIPT_OCR_PROVIDER=local_tesseract|openai|fixture|disabled
# Default: local_tesseract (free, private, on-device). Cloud is never selected
# merely because OPENAI_API_KEY exists — set RECEIPT_OCR_PROVIDER=openai explicitly.
# OPENAI_API_KEY=

# When false (default), the worker claims nothing and exits quickly
NOTIFICATION_DELIVERY_ENABLED=false

# Optional email channel (disabled unless fully configured)
EMAIL_NOTIFICATIONS_ENABLED=false
# EMAIL_PROVIDER=
# EMAIL_API_KEY=
# EMAIL_FROM=

# Application
# Production (Vercel Production env): APP_URL=https://household-os-five.vercel.app
# Development default when unset: http://localhost:3000
APP_URL=http://localhost:3000
APP_ENV=development

# Registration: bootstrap_only | invite_only | open
# open is rejected when APP_ENV=production
REGISTRATION_MODE=bootstrap_only
# Required when REGISTRATION_MODE=bootstrap_only (normalized to lowercase)
BOOTSTRAP_EMAIL=you@example.com

# Invitation link lifetime in hours (default 168 = 7 days)
INVITATION_TTL_HOURS=168

DEFAULT_TIMEZONE=America/Chicago
DEFAULT_CURRENCY=USD
